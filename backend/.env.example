# ── Security ────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7
CSRF_SECRET=change-this-to-another-random-secret-string

# ── Database ────────────────────────────────────────────────────────
# Leave empty for SQLite (default). Set for PostgreSQL.
DATABASE_URL=

# ── Server ──────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
ENVIRONMENT=development

# ── Rate Limiting ───────────────────────────────────────────────────
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_SEC=60

# ── Email (SMTP) ────────────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@automl.local

# ── File Uploads ────────────────────────────────────────────────────
MAX_UPLOAD_MB=500
