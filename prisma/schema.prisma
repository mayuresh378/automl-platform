generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Helpers ─────────────────────────────────────────────────────────

model Migration {
  id          String   @id @default(uuid())
  name        String
  applied_at  DateTime @default(now())
  checksum    String?
}

// ── Users ───────────────────────────────────────────────────────────

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  name              String
  passwordHash      String   @map("password_hash")
  role              String   @default("member")
  isActive          Boolean  @default(true) @map("is_active")
  emailVerified     Boolean  @default(false) @map("email_verified")
  verificationToken String?  @map("verification_token")
  resetToken        String?  @map("reset_token")
  resetTokenExpiry  DateTime? @map("reset_token_expiry")
  googleId          String?  @unique @map("google_id")
  avatarUrl         String?  @map("avatar_url")
  preferences       String?  @default("{}")
  mfaEnabled        Boolean  @default(false) @map("mfa_enabled")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  teams          TeamMember[]
  apiKeys        ApiKey[]
  auditLogs      AuditLog[]
  pipelines      Pipeline[]
  experiments    Experiment[]
  modelRegistry  ModelRegistry[]
  deployments    Deployment[]
  datasets       Dataset[]
  predictionLogs PredictionLog[]
  notifications  Notification[]
  projects       Project[]
  webhooks       Webhook[]
  sessions       UserSession[]
  activityLogs   ActivityLog[]

  @@map("users")
  @@index([createdAt])
  @@index([role])
}

// ── Teams ───────────────────────────────────────────────────────────

model Team {
  id        String   @id @default(uuid())
  name      String
  slug      String?  @unique
  plan      String   @default("free")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members TeamMember[]

  @@map("teams")
  @@index([slug])
  @@index([createdAt])
}

model TeamMember {
  id       String   @id @default(uuid())
  role     String   @default("member")
  joinedAt DateTime @default(now()) @map("joined_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("team_members")
  @@index([userId])
  @@index([teamId])
}

// ── Projects ────────────────────────────────────────────────────────

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("development")
  notes       String?
  tags        String?  @default("[]")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  experiments   Experiment[]
  modelRegistry ModelRegistry[]
  deployments   Deployment[]
  datasets      Dataset[]

  @@map("projects")
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status])
}

// ── API Keys ────────────────────────────────────────────────────────

model ApiKey {
  id          String   @id @default(uuid())
  name        String
  keyPrefix   String   @map("key_prefix")
  keyHash     String   @map("key_hash")
  status      String   @default("active")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
  @@index([userId])
  @@index([status])
  @@index([keyPrefix])
}

// ── Experiments ─────────────────────────────────────────────────────

model Experiment {
  id                String   @id @default(uuid())
  name              String
  model             String
  taskType          String?  @map("task_type")
  dataset           String?
  target            String?
  cvScore           Float?   @map("cv_score")
  metrics           String?  @default("{}")
  trainingTime      Float?   @map("training_time")
  totalTime         Float?   @map("total_time")
  memoryUsage       Float?   @map("memory_usage")
  cpuUsage          Float?   @map("cpu_usage")
  status            String   @default("success")
  params            String?  @default("{}")
  featureImportance String?  @map("feature_importance")
  confusionMatrix   String?  @map("confusion_matrix")
  runAt             DateTime? @map("run_at")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime @default(now()) @map("created_at")

  userId    String? @map("user_id")
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  projectId String? @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  modelRegistry ModelRegistry[]

  @@map("experiments")
  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@index([projectId, createdAt])
}

// ── Model Registry ──────────────────────────────────────────────────

model ModelRegistry {
  id          String   @id @default(uuid())
  name        String
  version     Int      @default(1)
  modelType   String?  @map("model_type")
  taskType    String?  @map("task_type")
  framework   String   @default("sklearn")
  filePath    String?  @map("file_path")
  fileSizeKb  Float?   @map("file_size_kb")
  cvScore     Float?   @map("cv_score")
  metrics     String?  @default("{}")
  params      String?  @default("{}")
  status      String   @default("staging")
  tags        String?  @default("[]")
  description String?
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  experimentId String? @map("experiment_id")
  experiment   Experiment? @relation(fields: [experimentId], references: [id], onDelete: SetNull)
  userId       String? @map("user_id")
  user         User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  projectId    String? @map("project_id")
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  deployments Deployment[]

  @@map("model_registry")
  @@index([userId])
  @@index([projectId])
  @@index([experimentId])
  @@index([status])
  @@index([createdAt])
  @@index([modelType])
}

// ── Deployments ─────────────────────────────────────────────────────

model Deployment {
  id             String   @id @default(uuid())
  name           String
  endpointUrl    String?  @map("endpoint_url")
  status         String   @default("active")
  environment    String   @default("production")
  requestsCount  Int      @default(0) @map("requests_count")
  avgLatencyMs   Float?   @map("avg_latency_ms")
  config         String?  @default("{}")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  modelId String? @map("model_id")
  model   ModelRegistry? @relation(fields: [modelId], references: [id], onDelete: SetNull)
  userId  String? @map("user_id")
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  projectId String? @map("project_id")
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@map("deployments")
  @@index([userId])
  @@index([projectId])
  @@index([modelId])
  @@index([status])
  @@index([environment])
  @@index([createdAt])
}

// ── Pipelines ───────────────────────────────────────────────────────

model Pipeline {
  id          String   @id @default(uuid())
  name        String
  description String?
  steps       String?  @default("[]")
  status      String   @default("draft")
  schedule    String?
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  runs PipelineRun[]

  @@map("pipelines")
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model PipelineRun {
  id          String    @id @default(uuid())
  status      String    @default("pending")
  currentStep String?   @map("current_step")
  results     String?   @default("{}")
  error       String?
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  pipelineId String @map("pipeline_id")
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@map("pipeline_runs")
  @@index([pipelineId])
  @@index([status])
  @@index([createdAt])
}

// ── Datasets ────────────────────────────────────────────────────────

model Dataset {
  id               String   @id @default(uuid())
  filename         String
  originalFilename String?  @map("original_filename")
  filePath         String?  @map("file_path")
  fileSizeKb       Float?   @map("file_size_kb")
  rows             Int?
  columns          String?  @default("[]")
  status           String   @default("uploaded")
  description      String?
  deletedAt        DateTime? @map("deleted_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  projectId String? @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId    String? @map("user_id")
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("datasets")
  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@index([filename])
  @@index([createdAt])
}

// ── Prediction Logs ─────────────────────────────────────────────────

model PredictionLog {
  id           String   @id @default(uuid())
  modelName    String   @map("model_name")
  inputPreview String?  @map("input_preview")
  prediction   String?
  confidence   Float?
  batchSize    Int      @default(1) @map("batch_size")
  latencyMs    Float?   @map("latency_ms")
  createdAt    DateTime @default(now()) @map("created_at")

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("prediction_logs")
  @@index([userId])
  @@index([modelName])
  @@index([createdAt])
}

// ── Notifications ───────────────────────────────────────────────────

model Notification {
  id           String   @id @default(uuid())
  title        String
  message      String?
  type         String   @default("info")
  category     String   @default("system")
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  read         Boolean  @default(false)
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime @default(now()) @map("created_at")

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
  @@index([userId])
  @@index([type])
  @@index([category])
  @@index([read])
  @@index([userId, read])
  @@index([createdAt])
}

// ── Webhooks ────────────────────────────────────────────────────────

model Webhook {
  id             String   @id @default(uuid())
  name           String
  url            String
  events         String?  @default("[]")
  secret         String?
  status         String   @default("active")
  lastTriggeredAt DateTime? @map("last_triggered_at")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("webhooks")
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ── User Sessions ───────────────────────────────────────────────────

model UserSession {
  id              String   @id @default(uuid())
  tokenHash       String   @map("token_hash")
  refreshTokenHash String? @map("refresh_token_hash")
  deviceInfo      String?  @map("device_info")
  ipAddress       String?  @map("ip_address")
  isActive        Boolean  @default(true) @map("is_active")
  lastUsedAt      DateTime @default(now()) @map("last_used_at")
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
  @@index([userId])
  @@index([isActive])
  @@index([tokenHash])
  @@index([expiresAt])
}

// ── Marketplace ─────────────────────────────────────────────────────

model MarketplaceItem {
  id          String   @id @default(uuid())
  name        String
  itemType    String   @map("item_type")
  description String?
  category    String?
  author      String?
  tags        String?  @default("[]")
  downloads   Int      @default(0)
  rating      Float    @default(0.0)
  featured    Boolean  @default(false)
  config      String?  @default("{}")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("marketplace_items")
  @@index([itemType])
  @@index([category])
  @@index([featured])
  @@index([createdAt])
}

// ── Audit Log ───────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid())
  actor        String?
  action       String
  target       String?
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  details      String?  @default("{}")
  ipAddress    String?  @map("ip_address")
  status       String   @default("success")
  severity     String   @default("info")
  createdAt    DateTime @default(now()) @map("created_at")

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
  @@index([userId])
  @@index([action])
  @@index([resourceType])
  @@index([resourceId])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
  @@index([userId, action, createdAt])
}

// ── Activity Log (user-facing timeline) ─────────────────────────────

model ActivityLog {
  id           String   @id @default(uuid())
  action       String
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  details      String?  @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("activity_logs")
  @@index([userId])
  @@index([action])
  @@index([resourceType])
  @@index([createdAt])
  @@index([userId, createdAt])
}
